// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ユーザーテーブル（Supabase Auth の auth.users と1対1で対応）
// id は Supabase Auth の UUID をそのまま使用
model User {
  id         String   @id // Supabase Auth の user.id (UUID)
  email      String   @unique
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  circle_members CircleMember[]

  @@map("users")
}

// サークルテーブル
model Circle {
  id         Int      @id @default(autoincrement())
  name       String
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  circle_members CircleMember[]
  players        Player[]
  courts         Court[]
  matches        Match[]

  @@map("circles")
}

// サークルへの所属＋ロール（admin / leader / member）
model CircleMember {
  id         Int      @id @default(autoincrement())
  circle_id  Int
  user_id    String   // Supabase Auth の user.id (UUID)
  role       String   // "admin" | "leader" | "member"
  created_at DateTime @default(now())

  circle Circle @relation(fields: [circle_id], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([circle_id, user_id])
  @@map("circle_members")
}

// 参加者テーブル
model Player {
  id         Int      @id @default(autoincrement())
  name       String
  level      Int?
  gender     String?
  is_present Boolean  @default(false)
  circle_id  Int?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  circle        Circle?       @relation(fields: [circle_id], references: [id], onDelete: SetNull)

  @@map("players")
}

// コートテーブル
model Court {
  id         Int      @id @default(autoincrement())
  circle_id  Int
  name       String
  match_type String
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  circle  Circle  @relation(fields: [circle_id], references: [id], onDelete: Cascade)
  matches Match[]

  @@map("courts")
}

// 試合結果テーブル
model Match {
  id               Int      @id @default(autoincrement())
  circle_id        Int
  court_id         Int
  match_type       String
  team1_player_ids Json
  team2_player_ids Json
  winner_team      Int?
  score            String?
  played_at        DateTime @default(now())
  created_at       DateTime @default(now())

  circle Circle @relation(fields: [circle_id], references: [id], onDelete: Cascade)
  court  Court  @relation(fields: [court_id], references: [id])

  @@map("matches")
}
